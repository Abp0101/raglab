RAGLAB_ENVIRONMENT=development
RAGLAB_LOG_LEVEL=INFO
RAGLAB_LOG_JSON=true
RAGLAB_CORS_ORIGINS=["http://localhost:3000"]
RAGLAB_AUTH_ENABLED=false
RAGLAB_AUTH_API_KEYS=[]
RAGLAB_MAX_UPLOAD_SIZE_MB=25
RAGLAB_MAX_PDF_PAGES=500
RAGLAB_INGESTION_CONCURRENCY=1
RAGLAB_INGESTION_LEASE_SECONDS=60
RAGLAB_INGESTION_POLL_SECONDS=1
RAGLAB_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAGLAB_EMBEDDING_BATCH_SIZE=32
RAGLAB_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RAGLAB_RERANKER_BATCH_SIZE=16
RAGLAB_QDRANT_COLLECTION=raglab_chunks
RAGLAB_QDRANT_TIMEOUT_SECONDS=30
RAGLAB_BM25_KEY_PREFIX=raglab:bm25
RAGLAB_LLM_PROVIDER=ollama
RAGLAB_LLM_MODEL=qwen3:8b
RAGLAB_ALLOW_PAID_API_USAGE=false
RAGLAB_OPENAI_BASE_URL=https://api.openai.com/v1
RAGLAB_OPENAI_API_KEY=
RAGLAB_OPENAI_INSTRUCTION_ROLE=developer
RAGLAB_OPENAI_STRUCTURED_OUTPUT_MODE=json_schema
RAGLAB_OPENAI_MAX_TOKENS_FIELD=max_completion_tokens
RAGLAB_OLLAMA_BASE_URL=http://localhost:11434
RAGLAB_LLM_TIMEOUT_SECONDS=120
RAGLAB_INPUT_COST_PER_MILLION=
RAGLAB_OUTPUT_COST_PER_MILLION=
HAYSTACK_TELEMETRY_ENABLED=false

RAGLAB_POSTGRES_DSN=postgresql+asyncpg://raglab:raglab@localhost:5432/raglab
RAGLAB_QDRANT_URL=http://localhost:6333
RAGLAB_QDRANT_API_KEY=
RAGLAB_REDIS_DSN=redis://localhost:6379/0
