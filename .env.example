RAGLAB_ENVIRONMENT=development
RAGLAB_LOG_LEVEL=INFO
RAGLAB_LOG_JSON=true
RAGLAB_CORS_ORIGINS=["http://localhost:3000"]
RAGLAB_MAX_UPLOAD_SIZE_MB=25
RAGLAB_MAX_PDF_PAGES=500
RAGLAB_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAGLAB_EMBEDDING_BATCH_SIZE=32
RAGLAB_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RAGLAB_RERANKER_BATCH_SIZE=16
RAGLAB_QDRANT_COLLECTION=raglab_chunks
RAGLAB_BM25_KEY_PREFIX=raglab:bm25

RAGLAB_POSTGRES_DSN=postgresql+asyncpg://raglab:raglab@localhost:5432/raglab
RAGLAB_QDRANT_URL=http://localhost:6333
RAGLAB_QDRANT_API_KEY=
RAGLAB_REDIS_DSN=redis://localhost:6379/0
